{
  "name": "setup-jlo",
  "version": "0.1.0",
  "description": "GitHub Action for setting up the jlo CLI",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "lint": "eslint .",
    "test": "vitest run",
    "build": "tsc --noEmit",
    "package": "ncc build -s src/index.ts -o dist --license licenses.txt",
    "verify:dist": "node ./scripts/verify-dist.mjs",
    "ci": "npm run lint && npm test && npm run build && npm run verify:dist"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.3",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^9.29.0",
    "globals": "^16.2.0",
    "js-yaml": "^4.1.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^3.2.4"
  }
}
